*.zip

# Claude Code local session state — never commit
.claude/

# Bash-scratch intermediate files under the automation-loop artifacts
# (sessionId vars / signing scratch / temp ids from verify scripts).
# The committed verify.log + JSON files under the same dirs are the
# durable record.
docs/.automation-loop/artifacts/**/.[!.]*
.f10-jwt

# Never commit env-dumps or aws describe-* raw output as evidence — the env
# arrays carry resolved secrets (DATABASE_URL_POOLER passwords, SST_KEY,
# COMPOSIO_API_KEY, etc.). H.7 leaked these on first push; redact to
# names-only or omit entirely.
docs/.automation-loop/artifacts/**/env-*.json
docs/.automation-loop/artifacts/**/task-def-raw*.json
.git-secret-replacements.txt
