# Dependencies — reinstalled inside the image via pnpm install
**/node_modules
.pnpm-store/

# Git
.git
.gitignore

# Build output — rebuilt inside the image (except worker/dist, which is
# pre-built on the host and copied into the alpine runtime image until
# the Dockerfile gains a workspace-aware build stage).
**/dist
!worker/dist
**/build
**/out
**/.next
**/.turbo
**/.output
**/.wxt
**/*.tsbuildinfo

# SST / IaC state
.sst
.aws
.vercel

# Env files
.env
.env.local
.env.*.local

# Tests / coverage
coverage

# Logs
*.log

# Editors / OS
.DS_Store
Thumbs.db
.idea
.vscode
*.swp


# sst
.sst