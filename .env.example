# Local dev: secrets come from Doppler (`doppler run --project backend --config dev --`).
# This file documents the variable names; do not commit real values here.

# Database (shared Supabase Postgres, runtime_* schema namespace)
DATABASE_URL=postgres://user:pass@host:5432/postgres
DB_URL=
MIGRATION_URL=postgres://user:pass@host:5432/postgres
# Prefer Supabase direct host for migrations (avoid transaction/session pooler):
# postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
SUPABASE_DIRECT_DATABASE_URL=
SUPABASE_MIGRATION_URL=
# Optional: force postgres-js default TLS verification on Supabase (omit relaxed TLS).
DATABASE_SSL_REJECT_UNAUTHORIZED=

# Supabase (auth — for /v1/auth/token Supabase access token verification)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# Workspace JWT issuer (HS256)
WORKSPACE_JWT_SECRET=change-me-in-prod

# LLM providers
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Voice
DEEPGRAM_API_KEY=

# Browser orchestration
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# AWS / SST (only needed for deploy, not local dev)
AWS_REGION=us-east-1

# EventBridge cron firing (Phase 10.5)
# Shared secret presented in X-Cron-Secret by EventBridge on cron-fired
# calls to /v1/runtime/workflows/:id/run-now. Optional in dev — leave
# unset to disable cron-secret auth (workspace JWT remains required).
# In production, set via `sst secret set RuntimeCronSecret <value>`.
RUNTIME_CRON_SECRET=
# Prefix for per-workflow EventBridge rules (e.g. `runtime-workflow`).
# When unset, the schedule lifecycle helpers are no-ops — dev/tests
# never call AWS. SST sets this in production.
EVENTBRIDGE_RULE_PREFIX=
# Target ARN (API destination) for cron-fired calls. Set by SST.
EVENTBRIDGE_API_DESTINATION_ARN=
# IAM role EventBridge assumes to invoke the API destination. Set by SST.
EVENTBRIDGE_TARGET_ROLE_ARN=

# Local dev: web → api base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Web dashboard auth (Supabase, browser-side via @supabase/ssr).
# These should equal SUPABASE_URL and SUPABASE_ANON_KEY above — duplicated so
# Next.js exposes them to the client bundle (NEXT_PUBLIC_ prefix). Sourced
# from Doppler `backend/dev` in local dev; from Vercel project env in prod.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
