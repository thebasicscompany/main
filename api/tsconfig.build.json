{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "declaration": false,
    "sourceMap": true,
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist",
    "dist-types",
    "node_modules",
    "src/**/*.test.ts",
    "vitest.config.ts",
    "drizzle.config.ts",
    "seeds",
    "src/gateway/**"
  ],
  "references": [{ "path": "./tsconfig.gateway.json" }]
}
