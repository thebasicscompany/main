{
  "name": "@basics/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build tsconfig.gateway.json && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --build tsconfig.gateway.json && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "e2e:live": "tsx scripts/e2e-live.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.0",
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-eventbridge": "^3.1044.0",
    "@aws-sdk/client-kms": "3.744.0",
    "@aws-sdk/client-scheduler": "^3.1044.0",
    "@aws-sdk/client-sqs": "^3.1044.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@basics/harness": "workspace:*",
    "@cfworker/json-schema": "^4.0.3",
    "@deepgram/sdk": "5.0.0",
    "@google/genai": "1.50.0",
    "@hono/node-server": "1.19.14",
    "@hono/zod-validator": "0.7.6",
    "@portkey-ai/mustache": "^2.1.3",
    "@smithy/signature-v4": "^2.1.1",
    "@supabase/supabase-js": "^2.103.3",
    "@types/mustache": "^4.2.5",
    "async-retry": "^1.3.3",
    "avsc": "^5.7.7",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.12",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "resend": "4.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/async-retry": "^1.4.5",
    "@types/node": "^22.10.0",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
