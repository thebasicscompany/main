{
  "name": "@basics/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "seed:templates": "tsx seeds/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.95.0",
    "@aws-sdk/client-eventbridge": "^3.1044.0",
    "@basics/harness": "workspace:*",
    "@deepgram/sdk": "5.0.0",
    "@google/genai": "1.50.0",
    "@hono/node-server": "1.19.14",
    "@hono/zod-validator": "0.7.6",
    "@supabase/supabase-js": "^2.103.3",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.12",
    "jose": "^6.2.2",
    "pino": "10.3.1",
    "postgres": "3.4.9",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
